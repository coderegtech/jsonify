{
  "name": "@coderegtech/jsonify-ws",
  "version": "1.5.5",
  "description": "Real-time JSON sync over WebSocket using Socket.IO. Drop-in React hook + Node server for collaborative JSON editing.",
  "keywords": [
    "json",
    "websocket",
    "sync",
    "real-time",
    "socket.io",
    "react",
    "hook",
    "collaborative",
    "editing"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "license": "MIT",
  "author": "coderegtech",
  "type": "commonjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.mjs",
      "require": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "server": "tsx src/server.ts"
  },
  "dependencies": {
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "react": "^18.3.1",
    "socket.io-client": "^4.8.3",
    "@types/react": "^18.3.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "socket.io-client": "^4.0.0"
  },
  "module": "dist/index.mjs"
}
